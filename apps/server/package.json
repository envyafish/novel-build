{
  "name": "@novel/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-sqlite --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-sqlite dist/server.js",
    "test": "node --experimental-sqlite --import tsx ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-sqlite --import tsx ./node_modules/vitest/vitest.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint skipped'"
  },
  "dependencies": {
    "@novel/shared": "workspace:*",
    "fastify": "4.27.0",
    "jszip": "^3.10.1",
    "pino": "9.1.0",
    "pino-pretty": "11.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "25.9.0",
    "tsx": "4.10.5",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
